{
    "version": 2,
    "cleanUrls": true,
    "builds": [
        {
            "src": "backend/main.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb"
            }
        },
        {
            "src": "backend/data/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(static|models)/(.*)",
            "dest": "/backend/data/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "backend/main.py"
        }
    ]
}