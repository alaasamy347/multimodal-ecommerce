{
    "version": 2,
    "builds": [
      {
        "src": "backend/main.py",
        "use": "@vercel/python",
        "config": {
          "maxLambdaSize": "50mb",
          "runtime": "python3.9"
        }
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "backend/main.py"
      }
    ],
    "env": {
      "KAGGLE_USERNAME": "@kaggle_username",
      "KAGGLE_KEY": "@kaggle_key",
      "GEMINI_API_KEY": "@gemini_api_key",
      "GROQ_API_KEY": "@groq_api_key",
      "OPENAI_API_KEY": "@openai_api_key"
    },
    "functions": {
      "backend/main.py": {
        "memory": 3008,
        "maxDuration": 60
      }
    }
  }